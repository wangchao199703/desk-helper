{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MinimalTodoApp",
  "version": "2.0.5",
  "identifier": "com.wangchao199703.minimaltodoapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "极简待办",
        "width": 520,
        "height": 720,
        "minWidth": 340,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "maximizable": false,
        "center": true,
        "skipTaskbar": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/AppData/Roaming/MinimalTodoApp/note-images/**",
          "$HOME/AppData/Roaming/MinimalTodoApp/group-icons/**",
          "$HOME/AppData/Roaming/MinimalTodoApp/clipboard-images/**",
          "$HOME/AppData/Roaming/MinimalTodoApp/screenshots/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}

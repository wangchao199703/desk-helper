<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 敦煌·石青（暖砂底 + 壁画石青，浅色;已调柔:暖砂底降饱和、更耐看） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#F4EFE5" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#ECE5D6" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#EFE8DA" />
    <SolidColorBrush x:Key="ContentBg"      Color="#F8F3EA" />
    <SolidColorBrush x:Key="CardBg"         Color="#FCF8F0" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#EEE7D8" />
    <SolidColorBrush x:Key="InputBg"        Color="#EFE8DA" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#3A2E20" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#6B5A45" />
    <SolidColorBrush x:Key="MutedText"      Color="#9C8A70" />
    <SolidColorBrush x:Key="Accent"         Color="#2E6E8E" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#DFD3BF" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#DEE6EA" />
    <SolidColorBrush x:Key="OverdueText"    Color="#B23A2E" />
    <SolidColorBrush x:Key="WarningText"    Color="#C08A2E" />
    <SolidColorBrush x:Key="SuccessText"    Color="#5E8A5A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FCF7EC" />
</ResourceDictionary>

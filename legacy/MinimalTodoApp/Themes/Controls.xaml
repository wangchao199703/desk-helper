    <!-- ===================== Mac 风格交通灯按钮 ===================== -->
    <!-- 用法：Tag 设为圆点颜色；Content 设为悬停时显示的符号（如 ✕ – +） -->
    <Style x:Key="TrafficLightButton" TargetType="Button">
        <Setter Property="Width" Value="13" />
        <Setter Property="Height" Value="13" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#80000000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- 用普通 Binding（而非 TemplateBinding）以便把 Tag 的十六进制字符串转换为画刷 -->
                        <Ellipse x:Name="dot"
                                 Fill="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                 Stroke="#22000000" StrokeThickness="0.5" />
                        <TextBlock x:Name="glyph" Text="{TemplateBinding Content}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}" Opacity="0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="glyph" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="glyph" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 现代细长滚动条 ===================== -->
    <!-- 半透明灰：在明亮/暗黑/透明等所有主题上都清晰可辨，无需逐主题配色。
         更细更透明，避免在窄侧栏里遮挡图标：默认 0x2E、悬停/拖动 0x66。 -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#55888888" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#99888888" />

    <!-- 翻页区：完全透明、不抢焦点（去掉默认的方块/箭头按钮） -->
    <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 圆角滑块：默认半透明，悬停/拖动时加深 -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <!-- 滑块元素宽度被 ScrollViewer 模板固定(改 Width 无效),
                         故只画一条靠右的细条(3px)作可见滑块,既细又不遮挡窄侧栏图标;
                         整块仍可拖动。竖向滚动条用;横向在本应用各列表均已禁用。 -->
                    <Grid Background="Transparent">
                        <Border x:Name="t" CornerRadius="2" Width="3" Margin="0,0,2,0"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource ScrollThumbBrush}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="t" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="t" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 默认（无 Key）样式：应用到所有 ScrollBar，含任务列表内的滚动条 -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <!-- 注:多数容器(侧栏/列表)的 ScrollViewer 会本地固定滚动条宽度,此 Width 仅作兜底;
             实际「细」由 ScrollThumb 模板里靠右的 3px 细条保证。 -->
        <Setter Property="Width" Value="6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                              Command="ScrollBar.PageUpCommand" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                              Command="ScrollBar.PageDownCommand" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <!-- 默认按竖向:仅约束最小「长度」(高)，宽度跟随滚动条粗细(6)。
                                     横向时在下方 Orientation 触发器里改约束最小宽、放开高。 -->
                                <Thumb x:Name="PART_Thumb" Style="{StaticResource ScrollThumb}" MinHeight="28" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===================== 浮层滚动条的 ScrollViewer（侧栏窄条用） =====================
         默认 ScrollViewer 把竖向滚动条排在内容右侧、占一截布局宽度,在窄侧栏里会把图标挤偏
         且与底部按钮不对齐;且其内部把滚动条宽度写死(样式改 Width 无效)。
         这里自建模板:滚动条**浮在内容之上**(同一 Grid 单元、右对齐),不占布局宽度——
         上方滚动区图标与底部按钮都按完整宽度居中、自然对齐;并由本地 Width 真正控制其粗细。 -->
    <Style x:Key="OverlayScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <ScrollContentPresenter Margin="{TemplateBinding Padding}"
                                                CanContentScroll="{TemplateBinding CanContentScroll}" />
                        <ScrollBar x:Name="PART_VerticalScrollBar" Orientation="Vertical"
                                   Width="8" HorizontalAlignment="Right"
                                   Minimum="0"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 优先级选择 Chip（对话框用） ===================== -->
    <Style x:Key="PriorityChip" TargetType="RadioButton">
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="b" CornerRadius="6" Padding="0,8"
                            Background="{DynamicResource InputBg}"
                            BorderThickness="1.5" BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- 选中时用 Tag 指定的优先级色描边 + 着色 -->
                            <Setter TargetName="b" Property="BorderBrush" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 右键菜单（自定义模板：不透明背景 + 主题文字 + 圆角，去掉系统默认左侧图标白条） ===================== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource PopupBg}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Divider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <!-- HasDropShadow 必须保持 True:否则承载弹窗 AllowsTransparency=False，圆角 Border 之外会被
             不透明弹窗填成方角。自定义模板本就不含系统方角阴影(SystemDropShadowChrome)。 -->
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <!-- 每次打开(Loaded)都播放与设置弹窗同款的"缩放 0.95→1 + 淡入"进场(自顶部展开) -->
                    <Border x:Name="menuRoot" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" Padding="0,4" Margin="0,0,6,6" SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="menuScale" />
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                        </Border.Effect>
                        <ItemsPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="menuRoot" Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1" Duration="0:0:0.15">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="menuScale" Storyboard.TargetProperty="ScaleX"
                                                     From="0.95" To="1" Duration="0:0:0.28">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="menuScale" Storyboard.TargetProperty="ScaleY"
                                                     From="0.95" To="1" Duration="0:0:0.28">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem 自定义模板：仅 标题列 + 子菜单箭头列（无图标 gutter，故不再有左侧白色矩形）。
         覆盖 SubmenuItem（普通项）与 SubmenuHeader（带子菜单，如“移动到分组”）两种角色。 -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid Margin="4,1">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" />
                        <Border x:Name="hoverBg" Background="{DynamicResource CardHoverBg}" CornerRadius="6" Opacity="0" />
                    <Border Padding="{TemplateBinding Padding}" Background="Transparent" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" ContentSource="Header"
                                              VerticalAlignment="Center" RecognizesAccessKey="True" />
                            <TextBlock x:Name="arrow" Grid.Column="1" Text="&#x203A;" FontWeight="Bold"
                                       Margin="14,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"
                                       Foreground="{DynamicResource SecondaryText}" />
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Right"
                                   HorizontalOffset="-2" Focusable="False" PopupAnimation="Fade"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource Divider}"
                                        BorderThickness="1" CornerRadius="8" Padding="0,4" Margin="0,0,10,10">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="arrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource Divider}" />
        <Setter Property="Margin" Value="6,3" />
    </Style>

    <!-- ===================== 圆角 ToolTip（系统默认是直角白底，改为主题圆角） ===================== -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource PopupBg}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Divider}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <!-- HasDropShadow 保持 True 以让承载弹窗透明，圆角 Border 才不会被方角弹窗填充 -->
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border x:Name="tipRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="9,6" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.28" Color="#000000" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 提示快速淡入(不缩放,提示不该抢戏) -->
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="tipRoot" Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1" Duration="0:0:0.15">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 圆角 ComboBox（系统下拉为直角，改为主题圆角；仅非可编辑下拉） ===================== -->
    <Style x:Key="ComboToggle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" Background="{DynamicResource InputBg}" CornerRadius="6"
                            BorderBrush="{DynamicResource Divider}" BorderThickness="1" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryText}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Grid Margin="4,1">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" />
                        <Border x:Name="hoverBg" Background="{DynamicResource CardHoverBg}" CornerRadius="6" Opacity="0" />
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource SelectedItemBg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Height" Value="32" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" Style="{StaticResource ComboToggle}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          Margin="10,0,26,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="None">
                            <!-- 下拉每次打开(Loaded)播放与设置弹窗同款"缩放 0.95→1 + 淡入"(自顶部展开) -->
                            <Border Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource Divider}"
                                    BorderThickness="1" CornerRadius="8" Padding="0,4" Margin="0,4,0,8"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}" SnapsToDevicePixels="True"
                                    RenderTransformOrigin="0.5,0">
                                <Border.RenderTransform>
                                    <ScaleTransform />
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                                </Border.Effect>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 From="0.95" To="1" Duration="0:0:0.28">
                                                    <DoubleAnimation.EasingFunction>
                                                        <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="0.95" To="1" Duration="0:0:0.28">
                                                    <DoubleAnimation.EasingFunction>
                                                        <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <ScrollViewer>
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 主题化 DatePicker / Calendar（系统默认为直角白底，深色主题下不可读） =====================
         DatePicker 会在运行时把 Calendar 注入弹窗 Child，故圆角与配色须落在 Calendar 自身的模板上. -->

    <!-- 日期按钮（每一天）。必须 keyed 并经 Calendar.CalendarDayButtonStyle 指派：
         WPF 的 Calendar 会把每个日按钮的 Style 绑定到 Owner.CalendarDayButtonStyle，
         该本地绑定会压制隐式样式，导致隐式样式不生效(日号沿用系统深色、深色皮肤下看不清)。 -->
    <Style x:Key="ThemedCalendarDayButton" TargetType="CalendarDayButton">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="26" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="bd" CornerRadius="6" Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="1" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentText}" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 月/年切换按钮（同理经 Calendar.CalendarButtonStyle 指派） -->
    <Style x:Key="ThemedCalendarButton" TargetType="CalendarButton">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="bd" CornerRadius="6" Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="1" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 上一月/下一月小箭头 -->
    <Style x:Key="CalendarNavButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="6" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 日历主体容器：圆角 + 主题底色（圆角弹窗的关键） -->
    <Style TargetType="CalendarItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarItem">
                    <!-- 星期表头（日 一 二…）：WPF 默认用硬编码深灰前景，在深色/毛玻璃皮肤下看不清，
                         此处提供主题化 DayTitle 模板，前景随主题(SecondaryText)。 -->
                    <ControlTemplate.Resources>
                        <DataTemplate x:Key="{x:Static primitives:CalendarItem.DayTitleTemplateResourceKey}">
                            <TextBlock Text="{Binding}" Foreground="{DynamicResource SecondaryText}"
                                       FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,2,0,4" />
                        </DataTemplate>
                    </ControlTemplate.Resources>
                    <Border Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource Divider}"
                            BorderThickness="1" CornerRadius="10" Padding="8" SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0">
                        <Border.RenderTransform>
                            <ScaleTransform />
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                        </Border.Effect>
                        <!-- 日历弹层每次打开播放与设置弹窗同款"缩放 0.95→1 + 淡入" -->
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         From="0.95" To="1" Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         From="0.95" To="1" Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- 头部：上一页 / 标题 / 下一页 -->
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PART_PreviousButton" Grid.Column="0" Style="{StaticResource CalendarNavButton}">
                                    <TextBlock Text="&#xE76B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" />
                                </Button>
                                <Button x:Name="PART_HeaderButton" Grid.Column="1" Foreground="{DynamicResource PrimaryText}"
                                        FontWeight="SemiBold" FontSize="13" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="hb" CornerRadius="6" Background="Transparent" Padding="8,3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="hb" Property="Background" Value="{DynamicResource CardHoverBg}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="PART_NextButton" Grid.Column="2" Style="{StaticResource CalendarNavButton}">
                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" />
                                </Button>
                            </Grid>
                            <!-- 月视图 / 年视图 -->
                            <Grid x:Name="PART_MonthView" Grid.Row="1" Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                            </Grid>
                            <Grid x:Name="PART_YearView" Grid.Row="1" Visibility="Hidden">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Year">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Decade">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource PopupBg}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Divider}" />
        <!-- 显式指派主题化日/月按钮样式：否则 Calendar 的 Style 绑定会让隐式样式失效 -->
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource ThemedCalendarDayButton}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource ThemedCalendarButton}" />
    </Style>

    <!-- DatePicker 输入框文本 -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePickerTextBox">
                    <Border Background="Transparent">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DatePicker 整体：圆角输入 + 日历图标按钮（弹窗里的 Calendar 已主题化为圆角） -->
    <Style TargetType="DatePicker">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Height" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Divider}"
                            BorderThickness="1" CornerRadius="6" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0"
                                               VerticalContentAlignment="Center" Margin="8,0,0,0"
                                               Background="Transparent" BorderThickness="0" />
                            <Button x:Name="PART_Button" Grid.Column="1" Width="30" Focusable="False"
                                    Cursor="Hand" Foreground="{DynamicResource SecondaryText}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="pb" CornerRadius="0,5,5,0" Background="Transparent">
                                            <TextBlock Text="&#xE787;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="pb" Property="Background" Value="{DynamicResource CardHoverBg}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Popup x:Name="PART_Popup" Placement="Bottom" StaysOpen="False"
                                   AllowsTransparency="True" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 全局清晰度：所有窗口启用像素对齐 + Display 文本渲染 =====================
         这些是继承属性，设在窗口根即向下级联到全部子元素，配合 app.manifest 的 Per-Monitor V2
         解决 1080p / 非整数缩放下文字发虚的问题. -->
    <Style TargetType="Window">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:MinimalTodoApp.Converters"
                    xmlns:infra="clr-namespace:MinimalTodoApp.Infrastructure"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">

    <!-- ===================== 转换器 ===================== -->
    <conv:NullToBoolConverter x:Key="NullToBool" />
    <conv:InverseBooleanConverter x:Key="InverseBool" />
    <conv:EmptyStringToVisibilityConverter x:Key="EmptyToVis" />
    <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    <conv:DueDateDisplayConverter x:Key="DueDisplay" />
    <conv:StringToBrushConverter x:Key="StringToBrush" />
    <conv:HexToLightBrushConverter x:Key="HexToLightBrush" />
    <conv:HalfWidthConverter x:Key="HalfWidth" />
    <conv:DueStateToBrushConverter x:Key="DueStateToBrush" />
    <conv:PriorityToBrushConverter x:Key="PriorityToBrush" />
    <conv:PriorityToLightBrushConverter x:Key="PriorityToLightBrush" />
    <conv:PriorityRingBrushConverter x:Key="PriorityRingBrush" />
    <conv:PriorityToTextConverter x:Key="PriorityToText" />
    <conv:EqualityToBoolConverter x:Key="EqualityToBool" />
    <conv:IndentToMarginConverter x:Key="IndentToMargin" />
    <conv:IndentToCardMarginConverter x:Key="IndentToCardMargin" />
    <conv:IndentFontSizeConverter x:Key="IndentFontSize" />
    <conv:PathToImageConverter x:Key="PathToImage" />

    <!-- ===================== 基础文字（字体/字号/行距随设置实时变化） ===================== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        <Setter Property="LineHeight" Value="{DynamicResource AppLineHeight}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <!-- ===================== 主按钮 ===================== -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource AccentText}" />
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="bScale" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- hover 平滑变浅(代替瞬时 Opacity Setter) -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Opacity"
                                                         To="0.88" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- 按压缩放反馈:按下轻缩 0.96,松开弹簧回弹(iOS 风格) -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleX"
                                                         To="0.96" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.96" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 幽灵按钮（透明，hover 显底色） ===================== -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- hover 用叠加层做透明度渐变(不能对主题共享画刷做颜色动画);按压整体轻缩回弹 -->
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="bScale" />
                        </Grid.RenderTransform>
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" />
                        <Border x:Name="hover" Background="{DynamicResource CardHoverBg}" CornerRadius="8" Opacity="0" />
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleX"
                                                         To="0.96" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.96" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 小图标按钮（删除 ×、添加 +） ===================== -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="bScale" />
                        </Grid.RenderTransform>
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="5" />
                        <Border x:Name="hover" Background="{DynamicResource CardHoverBg}" CornerRadius="5" Opacity="0" />
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleX"
                                                         To="0.92" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.92" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="bScale" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 圆角输入框 ===================== -->
    <Style x:Key="FlatTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBg}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="11,8" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 透明内联标题编辑框 ===================== -->
    <Style x:Key="TaskTitleTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2,1" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 扁平 ListBox（无边框/背景） ===================== -->
    <Style x:Key="FlatListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <!-- ===================== 侧边栏分组项 ===================== -->
    <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <!-- hover 用叠加层做透明度渐变(不能对主题共享画刷做颜色动画);选中态保持瞬时切换 -->
                    <Grid>
                        <Border x:Name="sel" Background="Transparent" CornerRadius="8" />
                        <Border x:Name="hover" Background="{DynamicResource CardHoverBg}" CornerRadius="8" Opacity="0" />
                        <Border x:Name="b" Background="Transparent" Padding="10,8">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <!-- 选中指示条:左侧强调色小圆条,选中时弹性展开(现代侧栏惯用) -->
                        <Border x:Name="ind" Width="3" Height="16" CornerRadius="1.5"
                                Background="{DynamicResource Accent}"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="indScale" ScaleY="0.4" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- 选中色块绑模型的 IsHighlighted(由 MainViewModel.RefreshSidebarSelection 统一计算,
                             全侧栏唯一),不再依赖 ListBoxItem.IsSelected——后者在多列表/OneWay 绑定下会残留. -->
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                            <Setter TargetName="sel" Property="Background" Value="{DynamicResource SelectedItemBg}" />
                            <Setter TargetName="ind" Property="Opacity" Value="1" />
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ind" Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="indScale" Storyboard.TargetProperty="ScaleY"
                                                         From="0.4" To="1" Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.5" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <!-- 取消选中必须用退场动画压掉进场 Storyboard 的保持值,否则切到其他分组后旧指示条仍亮着 -->
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ind" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="indScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.4" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                        <!-- 侧栏收起时收紧内边距，让窄条里有足够空间完整显示居中的圆形色点 -->
                        <DataTrigger Binding="{Binding DataContext.SidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter TargetName="b" Property="Padding" Value="4,8" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 任务项容器 ===================== -->
    <Style x:Key="TaskItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <!-- 卡片本身按缩进左移变窄;卡内"对勾到卡片左边框"的距离(Padding)与父任务一致;子任务上下间距减半 -->
                    <!-- hover 用内部叠加层做透明度渐变并加轻阴影"浮起"(不能对主题共享画刷做颜色动画) -->
                    <!-- 阴影挂在独立背景层 shadowHost(不含文字)上:DropShadowEffect 会把所在元素整棵子树位图化导致文字发虚,
                         故文字所在的 b 不带 Effect,阴影只作用于其后方等大同圆角的纯背景层,文字始终清晰. -->
                    <Grid Margin="{Binding IndentLevel, Converter={StaticResource IndentToCardMargin}}">
                        <Border x:Name="shadowHost" Background="{DynamicResource CardBg}" CornerRadius="12" />
                        <Border x:Name="b" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <Border x:Name="hover" Background="{DynamicResource CardHoverBg}" CornerRadius="11" Opacity="0" />
                                <Border Padding="14,9">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <!-- 优先级整条左脊(方案二):覆盖在卡片最左侧的实心 4px 色条(调浅色)。
                             覆盖层裁到卡片 12 圆角(RoundedClip),色条贴外缘 x=0(盖住 1px 边框故与外缘平齐),
                             上下两端随卡片圆角自然收口,与预览稿一致;不挡点击 -->
                        <Border x:Name="prioClip" infra:RoundedClip.Radius="12" IsHitTestVisible="False"
                                Visibility="{Binding DataContext.ShowPriorityBlock, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                            <Border Width="4" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                    Background="{Binding Priority, Converter={StaticResource PriorityToLightBrush}}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <!-- 轻阴影瞬时挂上(只作用于纯背景层,不影响文字清晰度) -->
                            <Setter TargetName="shadowHost" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270"
                                                      Opacity="0.16" Color="#000000" />
                                </Setter.Value>
                            </Setter>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hover" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 任务圆形勾选框（圆环按优先级着色，完成时填充 + 白色对勾） ===================== -->
    <!-- 用法：BorderBrush 绑定到 PriorityToBrush，圆环/填充即随优先级着色（取代旧的左侧色条与方框） -->
    <Style x:Key="TaskCheckBox" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <!-- 圆环直径随设置(AppCheckBoxSize，默认≈字号+2)，对勾用 Viewbox 等比缩放并在 24×24 设计稿内视觉居中 -->
                    <Grid Width="{DynamicResource AppCheckBoxSize}" Height="{DynamicResource AppCheckBoxSize}"
                          Background="Transparent">
                        <!-- 外圆环：填满容器，颜色取自 BorderBrush（= 优先级色） -->
                        <Ellipse x:Name="ring" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="2"
                                 Fill="Transparent" />
                        <!-- 完成时的白色对勾：放在 24×24 设计稿内，顶点略低于中心(≈60%)以视觉居中，Viewbox 等比缩放到圆环大小 -->
                        <Viewbox x:Name="checkbox" Stretch="Uniform" Opacity="0"
                                 RenderTransformOrigin="0.5,0.5">
                            <Viewbox.RenderTransform>
                                <ScaleTransform x:Name="checkScale" />
                            </Viewbox.RenderTransform>
                            <Grid Width="24" Height="24">
                                <Path Data="M 5.8 12.2 L 10 15 L 18.2 6.7"
                                      Stroke="White" StrokeThickness="3.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Viewbox>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ring" Property="Fill" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ring" Property="Fill"
                                    Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="checkbox" Property="Opacity" Value="1" />
                            <!-- 对勾弹跳:0→1.18→1 的过冲回弹(iOS 勾选手感),伴随快速淡入 -->
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="checkbox" Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="checkScale"
                                                                       Storyboard.TargetProperty="ScaleX">
                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.18" Value="1.18" KeySpline="0.2,0.8,0.3,1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="1" KeySpline="0.4,0,0.6,1" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="checkScale"
                                                                       Storyboard.TargetProperty="ScaleY">
                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.18" Value="1.18" KeySpline="0.2,0.8,0.3,1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="1" KeySpline="0.4,0,0.6,1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="checkbox" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 标题栏按钮（最小化 / 关闭到托盘） ===================== -->

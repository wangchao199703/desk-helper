<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Oat 燕麦主题（暖调低饱和米白） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#F5F2EC" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#ECE7DD" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#EFEAE0" />
    <SolidColorBrush x:Key="ContentBg"      Color="#F5F2EC" />
    <SolidColorBrush x:Key="CardBg"         Color="#FBF9F4" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#ECE7DD" />
    <SolidColorBrush x:Key="InputBg"        Color="#ECE7DD" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#3A352D" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#6B6356" />
    <SolidColorBrush x:Key="MutedText"      Color="#A39B8C" />
    <SolidColorBrush x:Key="Accent"         Color="#A8896B" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#E2DBCD" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#E8E0D0" />
    <SolidColorBrush x:Key="OverdueText"    Color="#B5675F" />
    <SolidColorBrush x:Key="WarningText"    Color="#B58A4A" />
    <SolidColorBrush x:Key="SuccessText"    Color="#7E9B6B" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FBF9F4" />
</ResourceDictionary>

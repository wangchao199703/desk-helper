<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Ocean 海洋主题（深蓝青绿） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#0F2027" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#0A171C" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#0B1A20" />
    <SolidColorBrush x:Key="ContentBg"      Color="#0F2027" />
    <SolidColorBrush x:Key="CardBg"         Color="#173540" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#1E454F" />
    <SolidColorBrush x:Key="InputBg"        Color="#173540" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#E0F2F1" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#A7C5C9" />
    <SolidColorBrush x:Key="MutedText"      Color="#5E7C82" />
    <SolidColorBrush x:Key="Accent"         Color="#2DD4BF" />
    <SolidColorBrush x:Key="AccentText"     Color="#06231F" />
    <SolidColorBrush x:Key="Divider"        Color="#1E454F" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#1C4D52" />
    <SolidColorBrush x:Key="OverdueText"    Color="#FF7B72" />
    <SolidColorBrush x:Key="WarningText"    Color="#F2C14E" />
    <SolidColorBrush x:Key="SuccessText"    Color="#5EEAD4" />

    <SolidColorBrush x:Key="PopupBg"        Color="#173540" />
</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Slate 板岩主题（低饱和蓝灰深色） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#282D33" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#20242A" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#20242A" />
    <SolidColorBrush x:Key="ContentBg"      Color="#282D33" />
    <SolidColorBrush x:Key="CardBg"         Color="#30363D" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#3A424B" />
    <SolidColorBrush x:Key="InputBg"        Color="#30363D" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#DDE3EA" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#AEB6C0" />
    <SolidColorBrush x:Key="MutedText"      Color="#79828D" />
    <SolidColorBrush x:Key="Accent"         Color="#8AA0B6" />
    <SolidColorBrush x:Key="AccentText"     Color="#1B1F24" />
    <SolidColorBrush x:Key="Divider"        Color="#3A424B" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#38414C" />
    <SolidColorBrush x:Key="OverdueText"    Color="#C77F79" />
    <SolidColorBrush x:Key="WarningText"    Color="#C6A567" />
    <SolidColorBrush x:Key="SuccessText"    Color="#8BAE8A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#30363D" />
</ResourceDictionary>

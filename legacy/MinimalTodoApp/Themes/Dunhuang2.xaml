<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 敦煌·土红（暖砂底 + 壁画土红，浅色;已调柔:暖砂底与土红降饱和、更耐看） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#F5EEE5" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#EDE2D5" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#F0E7DB" />
    <SolidColorBrush x:Key="ContentBg"      Color="#F8F2EB" />
    <SolidColorBrush x:Key="CardBg"         Color="#FDF9F1" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#EFE6DA" />
    <SolidColorBrush x:Key="InputBg"        Color="#F0E7DB" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#3D2C24" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#6F5649" />
    <SolidColorBrush x:Key="MutedText"      Color="#A48E7E" />
    <SolidColorBrush x:Key="Accent"         Color="#AE5E48" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#E3D5C5" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#EFE0D5" />
    <SolidColorBrush x:Key="OverdueText"    Color="#A8332B" />
    <SolidColorBrush x:Key="WarningText"    Color="#C0822E" />
    <SolidColorBrush x:Key="SuccessText"    Color="#5E8A5A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FDF8EF" />
</ResourceDictionary>

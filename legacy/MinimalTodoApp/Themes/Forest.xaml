<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Forest 森林主题（米色背景 + 墨绿点缀，明亮系） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#F4F6F0" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#E6EBDD" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#EAEFE0" />
    <SolidColorBrush x:Key="ContentBg"      Color="#F4F6F0" />
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#E6EBDD" />
    <SolidColorBrush x:Key="InputBg"        Color="#E6EBDD" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#26331F" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#4F6041" />
    <SolidColorBrush x:Key="MutedText"      Color="#8B9A7D" />
    <SolidColorBrush x:Key="Accent"         Color="#4D7C2F" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#D6DEC7" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#DCE7C8" />
    <SolidColorBrush x:Key="OverdueText"    Color="#C2410C" />
    <SolidColorBrush x:Key="WarningText"    Color="#B45309" />
    <SolidColorBrush x:Key="SuccessText"    Color="#3F7A1E" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FFFFFF" />
</ResourceDictionary>

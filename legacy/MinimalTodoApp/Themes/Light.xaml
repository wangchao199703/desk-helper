<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 明亮主题（所有主题键名必须完全一致） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#FFFFFF" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#F0F2F5" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#F5F6F8" />
    <SolidColorBrush x:Key="ContentBg"      Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#F0F2F5" />
    <SolidColorBrush x:Key="InputBg"        Color="#F0F2F5" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#1F2329" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#5A6470" />
    <SolidColorBrush x:Key="MutedText"      Color="#9AA4B0" />
    <SolidColorBrush x:Key="Accent"         Color="#007AFF" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#E6E8EB" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#EAF2FF" />
    <SolidColorBrush x:Key="OverdueText"    Color="#E5484D" />
    <SolidColorBrush x:Key="WarningText"    Color="#D9820B" />
    <SolidColorBrush x:Key="SuccessText"    Color="#16A34A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FFFFFF" />
</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 马卡龙·樱花（清甜樱花粉，浅色;已调柔:降低底色与强粉饱和、更耐看） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#FAF4F6" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#F4EAEE" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#F6EEF1" />
    <SolidColorBrush x:Key="ContentBg"      Color="#FCF7F9" />
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#F4E8ED" />
    <SolidColorBrush x:Key="InputBg"        Color="#F6EEF1" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#48303A" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#7A5A65" />
    <SolidColorBrush x:Key="MutedText"      Color="#B2929C" />
    <SolidColorBrush x:Key="Accent"         Color="#D9708F" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#EDDCE3" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#F6E6EC" />
    <SolidColorBrush x:Key="OverdueText"    Color="#E5484D" />
    <SolidColorBrush x:Key="WarningText"    Color="#D9820B" />
    <SolidColorBrush x:Key="SuccessText"    Color="#16A34A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FFFFFF" />
</ResourceDictionary>

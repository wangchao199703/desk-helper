<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 马卡龙·柠檬（清甜柠檬黄，浅色;已调柔:降低底色与亮黄饱和、更耐看） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#FAF7EE" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#F3EEDE" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#F6F1E3" />
    <SolidColorBrush x:Key="ContentBg"      Color="#FCFAF3" />
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#F1EBDA" />
    <SolidColorBrush x:Key="InputBg"        Color="#F6F1E3" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#403B26" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#6E6743" />
    <SolidColorBrush x:Key="MutedText"      Color="#A69D72" />
    <SolidColorBrush x:Key="Accent"         Color="#D2A53E" />
    <SolidColorBrush x:Key="AccentText"     Color="#3D2F00" />
    <SolidColorBrush x:Key="Divider"        Color="#E7DEC6" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#F2EAD2" />
    <SolidColorBrush x:Key="OverdueText"    Color="#E5484D" />
    <SolidColorBrush x:Key="WarningText"    Color="#C9820B" />
    <SolidColorBrush x:Key="SuccessText"    Color="#16A34A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FFFFFF" />
</ResourceDictionary>

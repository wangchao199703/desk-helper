<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 马卡龙·薄荷（清甜薄荷绿，浅色;已调柔:降低底色饱和、更耐看） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#F2F8F6" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#E7F1EE" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#EDF4F1" />
    <SolidColorBrush x:Key="ContentBg"      Color="#F7FBF9" />
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#E7F1EE" />
    <SolidColorBrush x:Key="InputBg"        Color="#EDF4F1" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#23403A" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#4C6A63" />
    <SolidColorBrush x:Key="MutedText"      Color="#82A39A" />
    <SolidColorBrush x:Key="Accent"         Color="#3BA793" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#DBEAE5" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#DEEFE9" />
    <SolidColorBrush x:Key="OverdueText"    Color="#E5484D" />
    <SolidColorBrush x:Key="WarningText"    Color="#D9820B" />
    <SolidColorBrush x:Key="SuccessText"    Color="#16A34A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FFFFFF" />
</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Graphite 石墨主题（低饱和中性深色） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#2A2C2E" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#232527" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#232527" />
    <SolidColorBrush x:Key="ContentBg"      Color="#2A2C2E" />
    <SolidColorBrush x:Key="CardBg"         Color="#323538" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#3B3E42" />
    <SolidColorBrush x:Key="InputBg"        Color="#323538" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#E4E6E8" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#B4B8BD" />
    <SolidColorBrush x:Key="MutedText"      Color="#7E848B" />
    <SolidColorBrush x:Key="Accent"         Color="#8FA1AE" />
    <SolidColorBrush x:Key="AccentText"     Color="#1F2123" />
    <SolidColorBrush x:Key="Divider"        Color="#3B3E42" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#3A4047" />
    <SolidColorBrush x:Key="OverdueText"    Color="#C77F79" />
    <SolidColorBrush x:Key="WarningText"    Color="#C7A668" />
    <SolidColorBrush x:Key="SuccessText"    Color="#8FB089" />

    <SolidColorBrush x:Key="PopupBg"        Color="#323538" />
</ResourceDictionary>

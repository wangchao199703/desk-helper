<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 暗黑主题（所有主题键名必须完全一致） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#1E1F22" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#17181B" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#17181B" />
    <SolidColorBrush x:Key="ContentBg"      Color="#1E1F22" />
    <SolidColorBrush x:Key="CardBg"         Color="#26282C" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#2E3136" />
    <SolidColorBrush x:Key="InputBg"        Color="#2A2C30" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#E6E8EB" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#B0B6BE" />
    <SolidColorBrush x:Key="MutedText"      Color="#6E767F" />
    <SolidColorBrush x:Key="Accent"         Color="#4C9AFF" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#303236" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#2B3A4D" />
    <SolidColorBrush x:Key="OverdueText"    Color="#FF6B6B" />
    <SolidColorBrush x:Key="WarningText"    Color="#F0A741" />
    <SolidColorBrush x:Key="SuccessText"    Color="#4ADE80" />

    <SolidColorBrush x:Key="PopupBg"        Color="#26282C" />
</ResourceDictionary>

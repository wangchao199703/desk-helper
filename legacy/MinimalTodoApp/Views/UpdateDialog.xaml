<Window x:Class="MinimalTodoApp.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inf="clr-namespace:MinimalTodoApp.Infrastructure"
        inf:Anim.Intro="True"
        Title="{DynamicResource S.Update.Title}"
        Width="520" Height="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <!-- 整窗可拖动:点击非交互区域即可移动 -->
    <Border Background="{DynamicResource PopupBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>

        <Grid Margin="24,20,24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题 + 版本 -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="{DynamicResource S.Update.Title}" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}" />
                <TextBlock x:Name="VersionText" FontSize="13" Margin="0,6,0,0"
                           Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" />
            </StackPanel>

            <!-- 更新内容标题 -->
            <TextBlock Grid.Row="1" Text="{DynamicResource S.Update.WhatsNew}" FontSize="13" FontWeight="SemiBold"
                       Margin="0,16,0,6" Foreground="{DynamicResource PrimaryText}" />

            <!-- 更新说明(可滚动) -->
            <Border Grid.Row="2" Background="{DynamicResource InputBg}" CornerRadius="8" Padding="12,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="NotesText" FontSize="12.5" TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}" LineHeight="20" />
                </ScrollViewer>
            </Border>

            <!-- 底部:进度态 / 按钮态 -->
            <Grid Grid.Row="3" Margin="0,16,0,0">
                <!-- 下载进度(默认隐藏) -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                    <TextBlock x:Name="ProgressText" Text="{DynamicResource S.Update.Downloading}" FontSize="12"
                               Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,6" />
                    <ProgressBar x:Name="DownloadProgress" Height="6" Minimum="0" Maximum="1"
                                 Foreground="{DynamicResource Accent}" Background="{DynamicResource InputBg}"
                                 BorderThickness="0" />
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource S.Update.SkipThis}" Style="{StaticResource GhostButton}"
                            Background="{DynamicResource InputBg}" Padding="12,7" Margin="0,0,8,0"
                            Click="SkipThis_Click" />
                    <Button Content="{DynamicResource S.Update.Ignore}" Style="{StaticResource GhostButton}"
                            Background="{DynamicResource InputBg}" Padding="12,7" Margin="0,0,8,0"
                            Click="Ignore_Click" />
                    <Button Content="{DynamicResource S.Update.Now}" Style="{StaticResource AccentButton}"
                            Padding="16,7" Click="UpdateNow_Click" />
                </StackPanel>

                <!-- 兜底:新版未能自动启动 → 提示手动运行(默认隐藏) -->
                <StackPanel x:Name="FallbackPanel" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource S.Update.LaunchFailed.Message}" FontSize="12.5"
                               TextWrapping="Wrap" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8" />
                    <Border Background="{DynamicResource InputBg}" CornerRadius="8" Padding="10,8">
                        <TextBox x:Name="NewExePathText" IsReadOnly="True" TextWrapping="Wrap"
                                 BorderThickness="0" Background="Transparent" FontSize="12"
                                 Foreground="{DynamicResource SecondaryText}"
                                 VerticalScrollBarVisibility="Auto" MaxHeight="60" />
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="{DynamicResource S.Update.Close}" Style="{StaticResource GhostButton}"
                                Background="{DynamicResource InputBg}" Padding="12,7" Margin="0,0,8,0"
                                Click="Ignore_Click" />
                        <Button Content="{DynamicResource S.Update.OpenFolder}" Style="{StaticResource GhostButton}"
                                Background="{DynamicResource InputBg}" Padding="12,7" Margin="0,0,8,0"
                                Click="OpenFolder_Click" />
                        <Button Content="{DynamicResource S.Update.RunNow}" Style="{StaticResource AccentButton}"
                                Padding="16,7" Click="RunNow_Click" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

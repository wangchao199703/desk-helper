<Window x:Class="MinimalTodoApp.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inf="clr-namespace:MinimalTodoApp.Infrastructure"
        inf:Anim.Intro="True"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Border Background="{DynamicResource PopupBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="22" Width="300">
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold"
                       Margin="0,0,0,10" Foreground="{DynamicResource PrimaryText}" />
            <TextBlock x:Name="MessageText" FontSize="13" TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryText}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="{DynamicResource S.Cancel}"
                        Style="{StaticResource GhostButton}" Click="Cancel_Click" Margin="0,0,8,0" />
                <Button x:Name="ConfirmButton" Content="{DynamicResource S.Confirm}"
                        Style="{StaticResource AccentButton}" Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

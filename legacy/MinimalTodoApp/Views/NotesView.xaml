<UserControl x:Class="MinimalTodoApp.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Microsoft YaHei UI, Segoe UI">

    <UserControl.Resources>
        <!-- 工具栏小按钮:GhostButton 收紧内边距;Focusable=False 是不夺走编辑框焦点的关键 -->
        <Style x:Key="NoteToolButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ===== 顶部格式工具栏 ===== -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource NoteToolButton}" FontWeight="Bold"
                        Content="B" Click="BoldButton_Click" ToolTip="{DynamicResource S.Note.Bold}" />
                <Button Style="{StaticResource NoteToolButton}" FontStyle="Italic"
                        Content="I" Click="ItalicButton_Click" ToolTip="{DynamicResource S.Note.Italic}" />
                <Button Style="{StaticResource NoteToolButton}"
                        Content="U" Click="UnderlineButton_Click" ToolTip="{DynamicResource S.Note.Underline}">
                    <Button.Resources>
                        <Style TargetType="TextBlock"><Setter Property="TextDecorations" Value="Underline" /></Style>
                    </Button.Resources>
                </Button>
                <Button Style="{StaticResource NoteToolButton}"
                        Content="S" Click="StrikeButton_Click" ToolTip="{DynamicResource S.Note.Strikethrough}">
                    <Button.Resources>
                        <Style TargetType="TextBlock"><Setter Property="TextDecorations" Value="Strikethrough" /></Style>
                    </Button.Resources>
                </Button>

                <Border Width="1" Margin="8,4" Background="{DynamicResource Divider}" />

                <Button Style="{StaticResource NoteToolButton}" FontWeight="Bold"
                        Content="H" Click="HeadingButton_Click" ToolTip="{DynamicResource S.Note.Heading}" />
                <Button Style="{StaticResource NoteToolButton}"
                        Content="•" Click="BulletButton_Click" ToolTip="{DynamicResource S.Note.Bullet}" />
                <Button Style="{StaticResource NoteToolButton}"
                        Content="☐" Click="TaskButton_Click" ToolTip="{DynamicResource S.Note.TaskList}" />

                <Border Width="1" Margin="8,4" Background="{DynamicResource Divider}" />

                <!-- 字体颜色:点开预设色板(自定义色保存到便签) -->
                <Button x:Name="ColorButton" Style="{StaticResource NoteToolButton}" FontWeight="Bold"
                        Content="A" Foreground="#E11D48" Click="ColorButton_Click"
                        ToolTip="{DynamicResource S.Note.TextColor}" />
                <Popup x:Name="ColorPopup" PlacementTarget="{Binding ElementName=ColorButton}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="{DynamicResource PopupBg}" CornerRadius="10" Margin="4"
                            BorderBrush="{DynamicResource Divider}" BorderThickness="1" Padding="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                        </Border.Effect>
                        <StackPanel Width="168">
                            <WrapPanel x:Name="ColorSwatches" />
                            <Button Content="{DynamicResource S.Note.DefaultColor}" Style="{StaticResource GhostButton}"
                                    HorizontalContentAlignment="Center" Margin="0,6,0,0" Padding="0,4"
                                    FontSize="12" Click="ClearColor_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- 插入图片:选图后复制到本地 note-images 目录并内嵌 -->
                <Button x:Name="ImageButton" Style="{StaticResource NoteToolButton}"
                        Content="&#xE91B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        Click="InsertImage_Click" ToolTip="{DynamicResource S.Note.InsertImage}" />
            </StackPanel>
        </Grid>

        <!-- ===== 富文本编辑器 ===== -->
        <Border CornerRadius="10" Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource Divider}" BorderThickness="1">
            <RichTextBox x:Name="Editor"
                         Background="Transparent" BorderThickness="0" Padding="14,10"
                         Foreground="{DynamicResource PrimaryText}"
                         CaretBrush="{DynamicResource PrimaryText}"
                         FontFamily="{Binding NoteFontFamily}"
                         FontSize="{Binding NoteFontSize}"
                         AcceptsTab="True" SpellCheck.IsEnabled="False"
                         VerticalScrollBarVisibility="Auto"
                         AllowDrop="True"
                         PreviewDragOver="Editor_PreviewDragOver"
                         PreviewDrop="Editor_PreviewDrop"
                         TextChanged="Editor_TextChanged">
                <RichTextBox.ContextMenu>
                    <ContextMenu Opened="EditorMenu_Opened">
                        <MenuItem x:Name="AddToTodoMenuItem" Header="{DynamicResource S.Note.AddToTodo}"
                                  Click="AddSelectionToTodo_Click" />
                        <Separator />
                        <MenuItem Command="ApplicationCommands.Cut" Header="{DynamicResource S.Menu.Cut}" />
                        <MenuItem Command="ApplicationCommands.Copy" Header="{DynamicResource S.Menu.Copy}" />
                        <MenuItem Command="ApplicationCommands.Paste" Header="{DynamicResource S.Menu.Paste}" />
                    </ContextMenu>
                </RichTextBox.ContextMenu>
                <RichTextBox.Resources>
                    <!-- 段落紧凑:一行一段,去掉默认段间距,读起来像逐行文本 -->
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </Border>
    </DockPanel>
</UserControl>

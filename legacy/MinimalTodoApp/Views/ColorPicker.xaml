<UserControl x:Class="MinimalTodoApp.Views.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Microsoft YaHei UI, Segoe UI">
    <StackPanel Width="232">
        <!-- 饱和度/明度方块 -->
        <Border CornerRadius="6" ClipToBounds="True" BorderBrush="{DynamicResource Divider}" BorderThickness="1">
            <Canvas x:Name="SVCanvas" Width="230" Height="150" Background="Transparent"
                    MouseLeftButtonDown="SV_MouseDown" MouseMove="SV_MouseMove" MouseLeftButtonUp="SV_MouseUp"
                    Cursor="Cross">
                <!-- 底色=当前色相 -->
                <Border x:Name="HueLayer" Width="230" Height="150" />
                <!-- 白→透明(横向) -->
                <Border Width="230" Height="150">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- 透明→黑(纵向) -->
                <Border Width="230" Height="150">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0" />
                            <GradientStop Color="#FF000000" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- 选择点 -->
                <Ellipse x:Name="SVThumb" Width="14" Height="14" Stroke="White" StrokeThickness="2"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.6" Color="#000000" />
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>
        </Border>

        <!-- 色相滑条 -->
        <Border CornerRadius="6" ClipToBounds="True" Margin="0,10,0,0"
                BorderBrush="{DynamicResource Divider}" BorderThickness="1">
            <Canvas x:Name="HueCanvas" Width="230" Height="16" Cursor="SizeWE"
                    MouseLeftButtonDown="Hue_MouseDown" MouseMove="Hue_MouseMove" MouseLeftButtonUp="Hue_MouseUp">
                <Border Width="230" Height="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFF0000" Offset="0.000" />
                            <GradientStop Color="#FFFFFF00" Offset="0.167" />
                            <GradientStop Color="#FF00FF00" Offset="0.333" />
                            <GradientStop Color="#FF00FFFF" Offset="0.500" />
                            <GradientStop Color="#FF0000FF" Offset="0.667" />
                            <GradientStop Color="#FFFF00FF" Offset="0.833" />
                            <GradientStop Color="#FFFF0000" Offset="1.000" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border x:Name="HueThumb" Width="6" Height="16" BorderBrush="White" BorderThickness="2"
                        IsHitTestVisible="False">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="2" ShadowDepth="0" Opacity="0.6" Color="#000000" />
                    </Border.Effect>
                </Border>
            </Canvas>
        </Border>

        <!-- 预览 + 十六进制 -->
        <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush x:Name="PreviewBrush" Color="#FFFFFF" />
                </Border.Background>
            </Border>
            <TextBox x:Name="HexBox" Grid.Column="1" Margin="8,0,0,0" VerticalContentAlignment="Center"
                     Style="{StaticResource FlatTextBox}" MaxLength="9"
                     KeyDown="HexBox_KeyDown" LostFocus="HexBox_LostFocus" />
        </Grid>
    </StackPanel>
</UserControl>

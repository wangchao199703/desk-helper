<Window x:Class="MinimalTodoApp.Views.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inf="clr-namespace:MinimalTodoApp.Infrastructure"
        inf:Anim.Intro="True"
        Title="{DynamicResource S.Help}"
        Width="460" SizeToContent="Height" MaxHeight="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Border Background="{DynamicResource PopupBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{DynamicResource S.Help.Title}" FontSize="17" FontWeight="SemiBold"
                       Margin="0,0,0,12" Foreground="{DynamicResource PrimaryText}" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="460">
                <StackPanel x:Name="ContentPanel" />
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{DynamicResource S.Help.Ok}" Style="{StaticResource AccentButton}" Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="MinimalTodoApp.Views.ThemeEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MinimalTodoApp.Views"
        xmlns:inf="clr-namespace:MinimalTodoApp.Infrastructure"
        inf:Anim.Intro="True"
        Title="{DynamicResource S.ThemeEditor.Title}"
        SizeToContent="Height" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Border Background="{DynamicResource PopupBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="22">
            <TextBlock x:Name="TitleText" Text="{DynamicResource S.ThemeEditor.Title}" FontSize="16" FontWeight="Bold"
                       Margin="0,0,0,14" Foreground="{DynamicResource PrimaryText}" />

            <!-- 名称 -->
            <TextBlock Text="{DynamicResource S.ThemeEditor.Name}" FontSize="13" Margin="0,0,0,5"
                       Foreground="{DynamicResource SecondaryText}" />
            <TextBox x:Name="NameBox" Style="{StaticResource FlatTextBox}"
                     Text="{DynamicResource S.ThemeEditor.DefaultName}" Margin="0,0,0,14" />

            <!-- 以现有主题为基础 -->
            <TextBlock Text="{DynamicResource S.ThemeEditor.BaseOn}" FontSize="13" Margin="0,0,0,5"
                       Foreground="{DynamicResource SecondaryText}" />
            <ComboBox x:Name="BaseBox" Margin="0,0,0,14"
                      DisplayMemberPath="Display" SelectionChanged="BaseBox_SelectionChanged" />

            <!-- 颜色字段 -->
            <ItemsControl x:Name="FieldList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryText}" FontSize="13" />
                            <!-- 点击色块弹出取色器(而非手输颜色) -->
                            <Button Grid.Column="1" Width="24" Height="24" Cursor="Hand"
                                    Tag="{Binding}" Click="Swatch_Click" ToolTip="{DynamicResource S.ThemeEditor.PickColor}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="sw" CornerRadius="5" BorderThickness="1"
                                                BorderBrush="{DynamicResource Divider}"
                                                Background="{Binding Value, Converter={StaticResource StringToBrush}}" />
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="sw" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource SecondaryText}" Text="{Binding Value}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{DynamicResource S.ThemeEditor.ColorHint}" FontSize="11"
                       Margin="0,2,0,0" Foreground="{DynamicResource MutedText}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="{DynamicResource S.Cancel}" Style="{StaticResource GhostButton}"
                        Click="Cancel_Click" Margin="0,0,8,0" />
                <Button Content="{DynamicResource S.SaveApply}" Style="{StaticResource AccentButton}"
                        Click="Ok_Click" />
            </StackPanel>

            <!-- 共享取色器弹层:点色块时定位到对应色块 -->
            <Popup x:Name="ColorPopup" StaysOpen="False" AllowsTransparency="True"
                   Placement="Right" PopupAnimation="Fade">
                <Border Background="{DynamicResource PopupBg}" CornerRadius="10" Margin="6"
                        BorderBrush="{DynamicResource Divider}" BorderThickness="1" Padding="12">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                    </Border.Effect>
                    <local:ColorPicker x:Name="Picker" />
                </Border>
            </Popup>
        </StackPanel>
    </Border>
</Window>

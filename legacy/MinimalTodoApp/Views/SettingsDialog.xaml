<Window x:Class="MinimalTodoApp.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inf="clr-namespace:MinimalTodoApp.Infrastructure"
        inf:Anim.Intro="True"
        Title="{DynamicResource S.Settings.Title}"
        Width="580" Height="468"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.Resources>
        <!-- 左侧分组导航项:选中态强调色、悬停态浅底 -->
        <Style x:Key="SettingsNavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="10,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ic" Text="{TemplateBinding Tag}" FontSize="15" Width="22"
                                           TextAlignment="Center" VerticalAlignment="Center" />
                                <ContentPresenter VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource InputBg}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 整窗可拖动:点击非交互区域(空白/标题/导航)即可移动窗口 -->
    <Border Background="{DynamicResource PopupBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============ 左侧:分组导航 ============ -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBg}"
                    CornerRadius="12,0,0,12" BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,1,0">
                <StackPanel Margin="12,18,12,12">
                    <TextBlock Text="{DynamicResource S.Settings.Title}" FontSize="16" FontWeight="Bold"
                               Margin="6,0,0,14" Foreground="{DynamicResource PrimaryText}" />
                    <RadioButton x:Name="GeneralNav" Style="{StaticResource SettingsNavItem}" Tag="⚙"
                                 Content="{DynamicResource S.Settings.Nav.General}" IsChecked="True"
                                 Checked="GeneralNav_Checked" />
                    <RadioButton x:Name="TodoNav" Style="{StaticResource SettingsNavItem}" Tag="✓"
                                 Content="{DynamicResource S.Settings.Nav.Todo}"
                                 Checked="TodoNav_Checked" />
                    <RadioButton x:Name="InboxNav" Style="{StaticResource SettingsNavItem}" Tag="▤"
                                 Content="{DynamicResource S.Settings.Nav.Inbox}"
                                 Checked="InboxNav_Checked" />
                    <RadioButton x:Name="AboutNav" Style="{StaticResource SettingsNavItem}" Tag="ⓘ"
                                 Content="{DynamicResource S.Settings.Nav.About}"
                                 Checked="AboutNav_Checked" />
                </StackPanel>
            </Border>

            <!-- ============ 右侧:对应分组的设置内容 ============ -->
            <Grid Grid.Column="1" Margin="22,18,22,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 待办设置组:任务区字体 + 待办相关开关 -->
                <ScrollViewer x:Name="TodoPanel" Grid.Row="0" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 任务区字体(修改后实时预览) -->
                        <TextBlock Text="{DynamicResource S.Settings.Font}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,2" />
                        <TextBlock Text="{DynamicResource S.Settings.FontDesc}" FontSize="11" Margin="0,0,0,14"
                                   TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />

                        <!-- 字体 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.FontFamily}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Fonts}" SelectedItem="{Binding SelectedFont}"
                                      DisplayMemberPath="Display" VerticalContentAlignment="Center" />
                        </Grid>

                        <!-- 字号 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.FontSize}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                            <Slider Grid.Column="1" Minimum="10" Maximum="18" Value="{Binding FontSize, Mode=TwoWay}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding FontSize, StringFormat={}{0:0}}" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedText}" />
                        </Grid>

                        <!-- 字号快捷档位:小(10) / 中(12) / 大(14) -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource GhostButton}" Content="{DynamicResource S.Size.Small}"
                                        Tag="10" Click="FontPreset_Click" MinWidth="52" Padding="0,5"
                                        Margin="0,0,8,0" Background="{DynamicResource InputBg}" />
                                <Button Style="{StaticResource GhostButton}" Content="{DynamicResource S.Size.Medium}"
                                        Tag="12" Click="FontPreset_Click" MinWidth="52" Padding="0,5"
                                        Margin="0,0,8,0" Background="{DynamicResource InputBg}" />
                                <Button Style="{StaticResource GhostButton}" Content="{DynamicResource S.Size.Large}"
                                        Tag="14" Click="FontPreset_Click" MinWidth="52" Padding="0,5"
                                        Background="{DynamicResource InputBg}" />
                            </StackPanel>
                        </Grid>

                        <!-- 行距 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.LineSpacing}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                            <Slider Grid.Column="1" Minimum="0.4" Maximum="1.8" Value="{Binding LineSpacing, Mode=TwoWay}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding LineSpacing, StringFormat={}{0:0.0}}" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedText}" />
                        </Grid>

                        <!-- 勾选框大小 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.CheckboxSize}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                            <Slider Grid.Column="1" Minimum="12" Maximum="24" Value="{Binding CheckboxSize, Mode=TwoWay}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding CheckboxSize, StringFormat={}{0:0}}" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedText}" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Divider}" Margin="0,12,0,16" />

                        <!-- 完成庆祝特效 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.Effects}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.EffectsDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="EffectsCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="Effects_Changed" Unchecked="Effects_Changed" />
                        </Grid>

                        <!-- 完成庆祝音效 -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.Sound}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.SoundDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="SoundCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="Sound_Changed" Unchecked="Sound_Changed" />
                        </Grid>

                        <!-- 周期提醒音效 -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.ReminderSound}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.ReminderSoundDesc}"
                                           FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="ReminderSoundCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="ReminderSound_Changed" Unchecked="ReminderSound_Changed" />
                        </Grid>

                        <!-- 显示节假日 -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.Holidays}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.HolidaysDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="HolidaysCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="Holidays_Changed" Unchecked="Holidays_Changed" />
                        </Grid>

                        <!-- 待办优先级色块(圆圈不显示颜色，前面加红/黄/绿色块) -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.PriorityBlock}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.PriorityBlockDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="PriorityBlockCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="PriorityBlock_Changed" Unchecked="PriorityBlock_Changed" />
                        </Grid>

                        <!-- 四象限·重要判定(是否把「中」优先级也算作重要) -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.QuadrantImportant}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.QuadrantImportantDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="QuadrantImportantCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="QuadrantImportant_Changed" Unchecked="QuadrantImportant_Changed" />
                        </Grid>

                        <!-- 四象限·紧急判定(是否把「3 天内到期」也算作紧急) -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.QuadrantUrgent}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.QuadrantUrgentDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="QuadrantUrgentCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="QuadrantUrgent_Changed" Unchecked="QuadrantUrgent_Changed" />
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!-- 收集箱设置组:便签专属字体/字号/行距(与任务区独立) -->
                <ScrollViewer x:Name="InboxPanel" Grid.Row="0" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource S.Settings.NoteFont}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,2" />
                        <TextBlock Text="{DynamicResource S.Settings.NoteFontDesc}" FontSize="11" Margin="0,0,0,14"
                                   TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />

                        <!-- 便签字体(修改后实时预览) -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.FontFamily}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Fonts}"
                                      SelectedItem="{Binding NotesVm.SelectedNoteFont}"
                                      DisplayMemberPath="Display" VerticalContentAlignment="Center" />
                        </Grid>

                        <!-- 便签字号 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.FontSize}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                            <Slider Grid.Column="1" Minimum="10" Maximum="18" Value="{Binding NotesVm.NoteFontSize, Mode=TwoWay}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding NotesVm.NoteFontSize, StringFormat={}{0:0}}" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedText}" />
                        </Grid>

                        <!-- 便签行距 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.LineSpacing}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                            <Slider Grid.Column="1" Minimum="0.4" Maximum="1.8" Value="{Binding NotesVm.NoteLineSpacing, Mode=TwoWay}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding NotesVm.NoteLineSpacing, StringFormat={}{0:0.0}}" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedText}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- 通用设置组:开机自启动 + 恢复默认设置(默认导航,排在最上) -->
                <ScrollViewer x:Name="GeneralPanel" Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 开机自启动 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.AutoStart}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.AutoStartDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="AutoStartCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="AutoStart_Changed" Unchecked="AutoStart_Changed" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Divider}" Margin="0,16,0,16" />

                        <!-- 恢复默认设置 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.RestoreDefaults}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.RestoreDefaultsDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <Button Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                    Style="{StaticResource GhostButton}" Background="{DynamicResource InputBg}"
                                    Padding="12,6" Content="{DynamicResource S.Settings.RestoreDefaults}"
                                    Click="RestoreDefaults_Click" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- 关于组：版本号 + 检查更新 + GitHub 链接 -->
                <ScrollViewer x:Name="AboutPanel" Grid.Row="0" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource S.Settings.Nav.About}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,14" />

                        <!-- 应用名 + 当前版本 -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource S.AppName}" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource InputBg}" CornerRadius="6" Padding="8,2" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="VersionText" FontSize="12"
                                           Foreground="{DynamicResource SecondaryText}" />
                            </Border>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource Divider}" Margin="0,16,0,16" />

                        <!-- 自动检查更新 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.AutoUpdate}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.AutoUpdateDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <CheckBox x:Name="AutoUpdateCheck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                      Checked="AutoUpdate_Changed" Unchecked="AutoUpdate_Changed" />
                        </Grid>

                        <!-- 手动检查更新 -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.CheckUpdate}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.CheckUpdateDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <Button x:Name="CheckUpdateButton" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                    Style="{StaticResource GhostButton}" Background="{DynamicResource InputBg}"
                                    Padding="12,6" Content="{DynamicResource S.Settings.CheckUpdate}"
                                    Click="CheckUpdate_Click" />
                        </Grid>

                        <!-- 手动下载更新:打开浏览器到最新发布页面，提示用户手动下载 exe 安装 -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.ManualDownload}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.ManualDownloadDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <Button Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                    Style="{StaticResource GhostButton}" Background="{DynamicResource InputBg}"
                                    Padding="12,6" Content="{DynamicResource S.Settings.ManualDownloadBtn}"
                                    Click="ManualDownload_Click" />
                        </Grid>

                        <!-- 重新安装当前版本:重新下载并安装相同版本(修复损坏/卡顿) -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.Settings.Reinstall}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.Settings.ReinstallDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <Button x:Name="ReinstallButton" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                    Style="{StaticResource GhostButton}" Background="{DynamicResource InputBg}"
                                    Padding="12,6" Content="{DynamicResource S.Settings.ReinstallBtn}"
                                    Click="Reinstall_Click" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Divider}" Margin="0,16,0,16" />

                        <!-- 支持开发者:邀请点 Star 支持项目，点击打开 GitHub 仓库 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource S.About.Support}" FontSize="14"
                                           Foreground="{DynamicResource PrimaryText}" />
                                <TextBlock Text="{DynamicResource S.About.SupportDesc}" FontSize="11"
                                           Margin="0,2,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />
                            </StackPanel>
                            <Button Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                    Style="{StaticResource GhostButton}" Background="{DynamicResource InputBg}"
                                    Padding="12,6" Content="{DynamicResource S.About.StarButton}"
                                    Click="RepoLink_Click" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部:状态文案 + 关闭 -->
                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Grid.Column="0" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedText}" TextWrapping="Wrap" />
                    <Button Grid.Column="1" Content="{DynamicResource S.Close}"
                            Style="{StaticResource AccentButton}" Click="Close_Click" />
                </Grid>

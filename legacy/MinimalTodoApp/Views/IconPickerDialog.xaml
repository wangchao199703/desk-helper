<Window x:Class="MinimalTodoApp.Views.IconPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inf="clr-namespace:MinimalTodoApp.Infrastructure"
        inf:Anim.Intro="True"
        Title="{DynamicResource S.IconPicker.Title}"
        SizeToContent="Height" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Border Background="{DynamicResource PopupBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="18" Width="320">
            <TextBlock Text="{DynamicResource S.IconPicker.Title}" FontSize="15" FontWeight="Bold"
                       Margin="0,0,0,12" Foreground="{DynamicResource PrimaryText}" />

            <!-- 分类按钮(按组可选) -->
            <WrapPanel x:Name="CatPanel" Margin="0,0,0,10" />

            <!-- 图标/图片网格 -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="6" MinHeight="124">
                <WrapPanel x:Name="IconPanel" />
            </Border>

            <!-- 自定义分类:导入图片 -->
            <Button x:Name="ImportButton" Content="{DynamicResource S.IconPicker.Import}"
                    Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                    Margin="0,10,0,0" Background="{DynamicResource InputBg}"
                    Click="Import_Click" Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{DynamicResource S.Close}" Style="{StaticResource AccentButton}" Click="Close_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

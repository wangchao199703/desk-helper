<Window x:Class="MinimalTodoApp.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提醒"
        Width="320" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        ResizeMode="NoResize" ShowActivated="False" Focusable="False"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Border Background="#F1232A33" CornerRadius="10"
            BorderBrush="#33FFFFFF" BorderThickness="1"
            Padding="14,12" Cursor="Hand" MouseLeftButtonUp="Toast_Click">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.45" Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="🔔" FontSize="14" Margin="0,0,6,0" Foreground="#FFC107" />
                <TextBlock x:Name="TitleText" Text="{DynamicResource S.Toast.DefaultTitle}" FontSize="13" FontWeight="Bold"
                           Foreground="#F5F7FA" />
            </StackPanel>
            <TextBlock x:Name="MessageText" FontSize="12" TextWrapping="Wrap"
                       Foreground="#C8D0DA" />
            <TextBlock x:Name="HintText" Text="{DynamicResource S.Toast.ClickToClose}" FontSize="10" Margin="0,6,0,0"
                       HorizontalAlignment="Right" Foreground="#7C8694" />
        </StackPanel>
    </Border>
</Window>
